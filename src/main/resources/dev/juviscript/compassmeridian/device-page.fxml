<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.juviscript.compassmeridian.controllers.DeviceController"
      spacing="16"
      maxHeight="Infinity"
      VBox.vgrow="ALWAYS">

    <!-- Hero Card — takes 50% of available height -->
    <HBox styleClass="card" spacing="24" alignment="CENTER_LEFT"
          VBox.vgrow="ALWAYS" maxHeight="Infinity">
        <!-- Placeholder image -->
        <StackPane styleClass="device-image-container"
                   maxWidth="200" maxHeight="200"
                   minWidth="200" minHeight="200">
            <ImageView fx:id="deviceImage" fitWidth="200" fitHeight="200" preserveRatio="true"/>
        </StackPane>

        <VBox HBox.hgrow="ALWAYS">
            <VBox styleClass="hero-card-header" spacing="8" alignment="CENTER_LEFT">
                <!-- Card Title -->
                <VBox>
                    <Label text="KLUTCH GAMING COMPASS" styleClass="card-title"/>
                    <HBox>
                        <!-- Device name — toggle between label and text field -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <StackPane>
                                <Label fx:id="deviceNameLabel" text="My Compass"
                                       styleClass="device-name"/>
                                <TextField fx:id="deviceNameField"
                                           styleClass="device-name-field"
                                           visible="false" managed="false"
                                           promptText="Enter device name..."
                                           onKeyPressed="#onDeviceNameKeyPressed"/>
                            </StackPane>
                            <!-- Edit/confirm icon — toggles between pencil and checkmark -->
                            <Label fx:id="editNameIcon" text="✎"
                                   styleClass="edit-icon"
                                   visible="false" managed="false"
                                   onMouseClicked="#onEditIconClicked"/>
                        </HBox>
                    </HBox>
                </VBox>

                <!-- Connection Status -->
                <HBox alignment="CENTER_LEFT">
                    <HBox fx:id="connBadge" styleClass="badge badge-red"
                          spacing="6" alignment="CENTER_LEFT">
                        <Label fx:id="connDot" text="●" styleClass="status-dot-disconnected"/>
                        <Label fx:id="connLabel" text="DISCONNECTED"/>
                    </HBox>
                </HBox>
            </VBox>

            <!-- Stats and Quick Actions -->
            <VBox styleClass="stats-container" spacing="12">
                <!-- Active Profile -->
                <HBox HBox.hgrow="ALWAYS" styleClass="stats-container-row">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="ACTIVE PROFILE" styleClass="card-title"/>
                        <Label text="WASD" styleClass="value-lg"/>
                        <Label text="DEFAULT" styleClass="badge" />
                    </VBox>
                </HBox>

                <!-- Total Profiles -->
                <HBox styleClass="stats-container-row" spacing="12">
                    <!-- Total Profiles -->
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="TOTAL PROFILES" styleClass="card-title"/>
                        <Label text="10" styleClass="value-lg"/>
                    </VBox>
                    <!-- Restart Button -->
                    <VBox styleClass="stat-card" spacing="2"
                          HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="QUICK ACTIONS" styleClass="card-title"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Button fx:id="restartButton" text="Restart Compass"
                                styleClass="btn-primary" onAction="#onRestartClicked"
                                disable="true"
                        >
                        <tooltip>
                            <Tooltip text="Compass not connected. Please connect your device."/>
                        </tooltip>
                        </Button>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <!-- Bottom row — also takes 50% -->
    <HBox spacing="24" alignment="CENTER_LEFT"
          VBox.vgrow="ALWAYS" maxHeight="Infinity">

        <!-- Device info card -->
        <VBox styleClass="card" spacing="12"
              HBox.hgrow="ALWAYS" maxWidth="Infinity"
              maxHeight="Infinity" VBox.vgrow="ALWAYS">
            <Label text="DEVICE INFO" styleClass="card-title"/>

            <GridPane hgap="16" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Device ID" styleClass="stat-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label text="compass-rp2040" styleClass="value"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Manufacturer" styleClass="stat-label"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label text="Klutch Gaming" styleClass="value"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Build Date" styleClass="stat-label"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="buildDateLabel" text="—" styleClass="value"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Port" styleClass="stat-label"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="portLabel" text="—" styleClass="value"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <!-- Firmware card -->
        <VBox styleClass="card" spacing="12"
              HBox.hgrow="ALWAYS" maxWidth="Infinity"
              maxHeight="Infinity" VBox.vgrow="ALWAYS">
            <Label text="FIRMWARE" styleClass="card-title"/>

            <GridPane hgap="16" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="INSTALLED" styleClass="stat-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="installedVersion" text="—" styleClass="value"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="HW REV" styleClass="stat-label"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="hwRevLabel" text="—" styleClass="value"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Check for Updates" styleClass="btn-secondary"
                    fx:id="checkUpdatesButton" onAction="#onCheckUpdates" maxWidth="Infinity"/>
        </VBox>
    </HBox>
</VBox>