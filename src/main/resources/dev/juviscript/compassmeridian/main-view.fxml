<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.juviscript.compassmeridian.controllers.MainController"
            styleClass="root"
            prefWidth="900"
            prefHeight="620">

    <!-- Custom Titlebar -->
    <top>
        <HBox styleClass="title-bar" alignment="CENTER_LEFT"
              onMousePressed="#onTitlebarPressed"
              onMouseDragged="#onTitlebarDragged">

            <ImageView fx:id="appIcon" fitWidth="20" fitHeight="20"
                       preserveRatio="true"/>

            <Label text="Klutch Gaming — Meridian" styleClass="title-bar-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Window controls -->
            <HBox styleClass="window-controls">
                <Button text="─" styleClass="btn-minimize"
                        onAction="#onMinimize"/>
                <Button text="□" styleClass="btn-maximize"
                        onAction="#onMaximize"/>
                <Button text="✕" styleClass="btn-close"
                        onAction="#onClose"/>
            </HBox>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="125" spacing="4">
            <VBox styleClass="sidebar-inner" VBox.vgrow="ALWAYS" maxHeight="Infinity">

                <!-- Logo -->
                <VBox styleClass="sidebar-logo" alignment="CENTER">
                    <ImageView fx:id="brandIcon" fitWidth="65" fitHeight="65"
                               preserveRatio="true"/>
                </VBox>

                <!-- Nav items -->
                <VBox fx:id="navDevice" styleClass="nav-item" onMouseClicked="#onNavDevice">
                    <Label text="⬡" styleClass="nav-icon"/>
                    <Label text="DEVICE" styleClass="nav-label"/>
                </VBox>

                <VBox fx:id="navMapping" styleClass="nav-item" onMouseClicked="#onNavMapping">
                    <Label text="⌨" styleClass="nav-icon"/>
                    <Label text="MAPPING" styleClass="nav-label"/>
                </VBox>

                <!-- Spacer pushes about button to bottom -->
                <Region VBox.vgrow="ALWAYS"/>

                <!-- About button -->
                <VBox fx:id="navAbout" styleClass="nav-item" onMouseClicked="#onNavAbout"
                      alignment="CENTER" style="-fx-padding: 8 0 8 0;">
                    <Label text="ⓘ" styleClass="nav-icon"
                           style="-fx-font-size: 16px;"/>
                    <Label text="ABOUT" styleClass="nav-label"/>
                </VBox>

            </VBox>
        </VBox>
    </left>

    <!-- Main content area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- Pages get swapped in here -->
        </StackPane>
    </center>

</BorderPane>
