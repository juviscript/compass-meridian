<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.juviscript.compassmeridian.controllers.MainController"
            styleClass="root"
            prefWidth="900"
            prefHeight="620">

    <!-- Custom Titlebar -->
    <top>
        <HBox styleClass="titlebar" alignment="CENTER_LEFT"
              onMousePressed="#onTitlebarPressed"
              onMouseDragged="#onTitlebarDragged">
            <padding>
                <Insets top="0" right="0" bottom="0" left="16"/>
            </padding>

            <ImageView fx:id="appIcon" fitWidth="20" fitHeight="20"
                       preserveRatio="true"/>

            <Label text="MERIDIAN" styleClass="titlebar-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Window controls -->
            <HBox styleClass="window-controls">
                <Button text="─" styleClass="btn-minimize"
                        onAction="#onMinimize"/>
                <Button text="□" styleClass="btn-maximize"
                        onAction="#onMaximize"/>
                <Button text="✕" styleClass="btn-close"
                        onAction="#onClose"/>
            </HBox>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="180">
            <padding>
                <Insets top="24" right="0" bottom="24" left="0"/>
            </padding>

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" alignment="CENTER">
                <padding>
                    <Insets bottom="32"/>
                </padding>
                <ImageView fx:id="brandIcon" fitWidth="40" fitHeight="40"
                           preserveRatio="true"/>
                <Label text="KLUTCH GAMING" styleClass="brand-label"/>
            </VBox>

            <!-- Nav items -->
            <VBox fx:id="navContainer" spacing="4">
                <padding>
                    <Insets left="12" right="12"/>
                </padding>

                <VBox fx:id="navDevice" styleClass="nav-item" onMouseClicked="#onNavDevice">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label text="⬡" styleClass="nav-icon"/>
                    <Label text="Device" styleClass="nav-label"/>
                </VBox>

                <VBox fx:id="navMapping" styleClass="nav-item" onMouseClicked="#onNavMapping">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label text="⌨" styleClass="nav-icon"/>
                    <Label text="Mapping" styleClass="nav-label"/>
                </VBox>

                <VBox fx:id="navProfiles" styleClass="nav-item" onMouseClicked="#onNavProfiles">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label text="☰" styleClass="nav-icon"/>
                    <Label text="Profiles" styleClass="nav-label"/>
                </VBox>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Connection status at bottom of sidebar -->
            <VBox styleClass="sidebar-status" alignment="CENTER">
                <padding><Insets top="16" right="16" bottom="0" left="16"/></padding>
                <HBox spacing="8" alignment="CENTER">
                    <Label fx:id="statusDot" text="●" styleClass="status-dot-disconnected"/>
                    <Label fx:id="statusLabel" text="Disconnected" styleClass="status-text"/>
                </HBox>
                <Button fx:id="connectButton" text="Connect"
                        onAction="#onConnectClicked"
                        styleClass="btn-connect" maxWidth="Infinity"/>
            </VBox>

        </VBox>
    </left>

    <!-- Main content area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- Pages get swapped in here -->
        </StackPane>
    </center>

</BorderPane>