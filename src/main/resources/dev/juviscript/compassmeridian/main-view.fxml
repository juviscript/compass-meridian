<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.juviscript.compassmeridian.controllers.MainController"
            styleClass="root"
            prefWidth="1280"
            prefHeight="800">

    <!-- Custom Titlebar -->
    <top>
        <HBox styleClass="title-bar" alignment="CENTER_LEFT"
              onMousePressed="#onTitlebarPressed"
              onMouseDragged="#onTitlebarDragged">

            <ImageView fx:id="appIcon" fitWidth="20" fitHeight="20"
                       preserveRatio="true"/>

            <Label text="Klutch Gaming — Meridian" styleClass="title-bar-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox styleClass="window-controls">
                <Button text="─" styleClass="btn-minimize" onAction="#onMinimize"/>
                <Button text="□" styleClass="btn-maximize" onAction="#onMaximize"/>
                <Button text="✕" styleClass="btn-close"    onAction="#onClose"/>
            </HBox>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200">
            <VBox styleClass="sidebar-inner" VBox.vgrow="ALWAYS" maxHeight="Infinity">

                <!-- Logo -->
                <VBox styleClass="sidebar-logo" alignment="CENTER" spacing="6">
                    <ImageView fx:id="brandIcon" fitWidth="80" fitHeight="80"
                               preserveRatio="true"/>
                </VBox>

                <!-- Nav items -->
                <HBox fx:id="navDevice" styleClass="nav-item"
                      onMouseClicked="#onNavDevice" alignment="CENTER_LEFT"
                      spacing="15">
                    <StackPane minWidth="30" prefWidth="30">
                    <Label text="⬡" styleClass="nav-icon"/>
                    </StackPane>
                    <Label text="DASHBOARD" styleClass="nav-label"/>
                </HBox>

                <HBox fx:id="navMapping" styleClass="nav-item"
                      onMouseClicked="#onNavMapping" alignment="CENTER_LEFT"
                      spacing="15">
                    <StackPane minWidth="30" prefWidth="30">
                    <Label text="⌨" styleClass="nav-icon"/>
                    </StackPane>

                    <Label text="MAPPING" styleClass="nav-label"/>
                </HBox>

                <HBox fx:id="navHelp" styleClass="nav-item"
                      onMouseClicked="#onNavHelp" alignment="CENTER_LEFT"
                      spacing="15">
                    <StackPane minWidth="30" prefWidth="30">
                    <Label text="?" styleClass="nav-icon"/>
                    </StackPane>

                    <Label text="HELP" styleClass="nav-label"/>
                </HBox>

                <!-- Spacer -->
                <Region VBox.vgrow="ALWAYS"/>

                <!-- App Settings -->
                <!-- About -->
                <HBox fx:id="navAbout" styleClass="nav-item"
                      onMouseClicked="#onNavAbout" alignment="CENTER_LEFT"
                      spacing="12">
                    <StackPane minWidth="30" prefWidth="30">

                    <Label text="ⓘ" styleClass="nav-icon"/>
                    </StackPane>

                    <Label text="About" styleClass="nav-label"/>
                </HBox>

            </VBox>
        </VBox>
    </left>

    <!-- Main content area — StackPane for toast overlay -->
    <center>
        <StackPane fx:id="rootPane" styleClass="content-area">
            <StackPane fx:id="contentArea"/>
        </StackPane>
    </center>

</BorderPane>
