<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.juviscript.compassmeridian.controllers.AboutController"
      styleClass="modal-root"
      spacing="0"
      prefWidth="320">

    <!-- Titlebar -->
    <HBox styleClass="modal-titlebar" alignment="CENTER_LEFT"
          onMousePressed="#onTitlebarPressed"
          onMouseDragged="#onTitlebarDragged">
        <Label text="ABOUT MERIDIAN" styleClass="modal-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="btn-close" onAction="#onCloseClicked"/>
    </HBox>

    <!-- Content -->
    <VBox spacing="20" style="-fx-padding: 24; -fx-alignment: CENTER;">

        <!-- Logo -->
        <VBox alignment="CENTER" spacing="6">
            <ImageView fx:id="aboutLogo" fitWidth="56" fitHeight="56"
                       preserveRatio="true"/>
            <Label text="MERIDIAN" styleClass="card-title"
                   style="-fx-font-size: 18px; -fx-letter-spacing: 4px;"/>
            <Label fx:id="versionLabel" text="v0.1.0"
                   styleClass="text-secondary"
                   style="-fx-font-size: 11px;"/>
        </VBox>

        <Separator/>

        <!-- Info -->
        <VBox spacing="8" alignment="CENTER">
            <Label text="Configuration app for the Klutch Gaming Compass"
                   styleClass="text-secondary"
                   style="-fx-font-size: 11px; -fx-wrap-text: true; -fx-text-alignment: center;"/>
        </VBox>

        <!-- Developer -->
        <VBox spacing="4" alignment="CENTER">
            <Label text="DEVELOPER" styleClass="card-title"
                   style="-fx-font-size: 9px;"/>
            <Label text="Juviscript · Klutch Gaming"
                   styleClass="value"
                   style="-fx-font-size: 12px;"/>
        </VBox>

        <!-- License -->
        <VBox spacing="4" alignment="CENTER">
            <Label text="LICENSE" styleClass="card-title"
                   style="-fx-font-size: 9px;"/>
            <Label text="MIT License"
                   styleClass="value"
                   style="-fx-font-size: 12px;"/>
        </VBox>

        <Separator/>

        <!-- Copyright -->
        <Label text="© 2026 Klutch Gaming. All rights reserved."
               styleClass="text-secondary"
               style="-fx-font-size: 10px;"/>

    </VBox>

</VBox>
