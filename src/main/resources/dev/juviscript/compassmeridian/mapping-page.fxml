<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.juviscript.compassmeridian.controllers.MappingController"
      spacing="20"
      maxHeight="Infinity"
      VBox.vgrow="ALWAYS">

    <!-- Top row -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- ── Left — Key Mapping + Deadzone ───────────── -->
        <VBox styleClass="card" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity" prefWidth="0">

            <Label text="KEY MAPPING" styleClass="card-title"/>

            <!-- D-Pad -->
            <VBox alignment="CENTER" spacing="0">

                <!-- Up -->
                <HBox alignment="CENTER" prefHeight="64">
                    <ComboBox fx:id="upCombo" styleClass="dpad-combo"
                              prefWidth="100" onAction="#onMappingChanged"/>
                </HBox>

                <!-- Middle row -->
                <HBox alignment="CENTER" spacing="0" prefHeight="64">
                    <HBox alignment="CENTER" prefWidth="120">
                        <ComboBox fx:id="leftCombo" styleClass="dpad-combo"
                                  prefWidth="100" onAction="#onMappingChanged"/>
                    </HBox>
                    <HBox alignment="CENTER" prefWidth="70">
                        <Label text="+" styleClass="dpad-center"/>
                    </HBox>
                    <HBox alignment="CENTER" prefWidth="120">
                        <ComboBox fx:id="rightCombo" styleClass="dpad-combo"
                                  prefWidth="100" onAction="#onMappingChanged"/>
                    </HBox>
                </HBox>

                <!-- Down -->
                <HBox alignment="CENTER" prefHeight="64">
                    <ComboBox fx:id="downCombo" styleClass="dpad-combo"
                              prefWidth="100" onAction="#onMappingChanged"/>
                </HBox>

                <!-- Click -->
                <VBox alignment="CENTER" spacing="10" prefHeight="44">
                    <Label text="● CLICK" styleClass="dpad-label"
                           style="-fx-font-size: 10px;"/>
                    <ComboBox fx:id="clickCombo" styleClass="dpad-combo"
                              prefWidth="100" onAction="#onMappingChanged"/>
                </VBox>
            </VBox>

            <Separator/>

            <!-- Deadzone -->
            <VBox spacing="10">
                <Label text="DEADZONE" styleClass="card-title"/>

                <!-- Directional -->
                <VBox spacing="-1">
                    <Label text="Directional" styleClass="stat-label"/>
                    <HBox spacing="10" alignment="CENTER" prefHeight="48">
                        <StackPane HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Slider fx:id="thresholdSlider" min="50" max="150"
                                    value="30" maxWidth="Infinity" styleClass="sensitivity-slider"/>
                            <HBox alignment="CENTER_LEFT" mouseTransparent="true"
                                  style="-fx-padding: 0 12 0 12;">
                                <Label text="← Less sensitive" styleClass="stat-label"
                                       style="-fx-font-size: 9px; -fx-text-fill: #404060;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="More sensitive →" styleClass="stat-label"
                                       style="-fx-font-size: 9px; -fx-text-fill: #404060;"/>
                            </HBox>
                        </StackPane>
                        <Label fx:id="thresholdLabel" text="120" styleClass="value"
                               style="-fx-min-width: 36px; -fx-font-size: 11px;"/>
                    </HBox>
                </VBox>

                <!-- Diagonal -->
                <VBox spacing="-1">
                <Label text="Diagonal" styleClass="stat-label"/>
                <HBox spacing="10" alignment="CENTER" prefHeight="48">
                    <StackPane HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Slider fx:id="diagonalSlider" min="30" max="100"
                                value="40" maxWidth="Infinity"
                                showTickMarks="false" styleClass="sensitivity-slider"/>
                        <HBox alignment="CENTER_LEFT" mouseTransparent="true"
                              style="-fx-padding: 0 12 0 12;">
                            <Label text="← Less sensitive" styleClass="stat-label"
                                   style="-fx-font-size: 9px; -fx-text-fill: #404060;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="More sensitive →" styleClass="stat-label"
                                   style="-fx-font-size: 9px; -fx-text-fill: #404060;"/>
                        </HBox>
                    </StackPane>
                    <Label fx:id="diagonalLabel" text="60" styleClass="value"
                           style="-fx-min-width: 36px; -fx-font-size: 11px;"/>
                </HBox>
                </VBox>
            </VBox>

            <!-- Actions -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="resetButton" text="Reset"
                        onAction="#onResetClicked" styleClass="btn-secondary"
                        style="-fx-padding: 6 14 6 14; -fx-font-size: 10px;"/>
                <Button fx:id="saveAsProfileButton" text="Save as Profile"
                        onAction="#onSaveAsProfileClicked" styleClass="btn-secondary"
                        style="-fx-padding: 6 14 6 14; -fx-font-size: 10px;"/>
                <Button fx:id="saveButton" text="Apply"
                        onAction="#onSaveClicked" styleClass="btn-primary"
                        style="-fx-padding: 6 14 6 14; -fx-font-size: 10px;"/>
            </HBox>
        </VBox>
        <!-- ── End Left card ────────────────────────────── -->

        <!-- ── Right — Profiles ─────────────────────────── -->
        <VBox spacing="20" HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <!-- Built-in Presets -->
            <VBox styleClass="card" spacing="14">
                <Label text="BUILT-IN PRESETS" styleClass="card-title"/>
                <VBox fx:id="builtinProfilesList" spacing="8"/>
            </VBox>

            <!-- Custom Profiles -->
            <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="CUSTOM PROFILES" styleClass="card-title"
                           HBox.hgrow="ALWAYS"/>
                    <Label fx:id="customCountLabel" text="0 / 10"
                           styleClass="text-secondary"
                           style="-fx-font-size: 10px;"/>
                </HBox>

                <Label fx:id="noCustomLabel" text="No custom profiles yet."
                       styleClass="text-secondary"
                       style="-fx-font-size: 11px;"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            styleClass="profile-scroll">
                    <VBox fx:id="customProfilesList" spacing="8"/>
                </ScrollPane>

                <Button text="+ Create New Profile"
                        onAction="#onSaveAsProfileClicked"
                        styleClass="btn-create-profile"
                        maxWidth="Infinity"/>
            </VBox>

        </VBox>
        <!-- ── End Right ────────────────────────────────── -->

    </HBox>

</VBox>
