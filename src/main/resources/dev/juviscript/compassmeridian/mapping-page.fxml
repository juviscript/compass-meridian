<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.juviscript.compassmeridian.controllers.MappingController"
      spacing="16"
      maxHeight="Infinity"
      VBox.vgrow="ALWAYS">

    <!-- Top row — Key Mapping + Built-in Presets -->
    <HBox spacing="16">

        <!-- Left — D-Pad Key Mapping -->
        <VBox styleClass="card" spacing="16"
              HBox.hgrow="ALWAYS" maxWidth="Infinity"
              prefWidth="0">

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="KEY MAPPING" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="saveProfileStatus" text=""
                       style="-fx-font-size: 10px;"/>
            </HBox>

            <!-- D-Pad -->
            <VBox alignment="CENTER" spacing="0">

                <!-- Up -->
                <HBox alignment="CENTER" prefHeight="60">
                    <ComboBox fx:id="upCombo" styleClass="dpad-combo"
                              prefWidth="90" onAction="#onMappingChanged"/>
                </HBox>

                <!-- Middle row -->
                <HBox alignment="CENTER" spacing="0" prefHeight="60">
                    <HBox alignment="CENTER" prefWidth="110">
                        <ComboBox fx:id="leftCombo" styleClass="dpad-combo"
                                  prefWidth="90" onAction="#onMappingChanged"/>
                    </HBox>
                    <HBox alignment="CENTER" prefWidth="60">
                        <Label text="+" styleClass="dpad-center"/>
                    </HBox>
                    <HBox alignment="CENTER" prefWidth="110">
                        <ComboBox fx:id="rightCombo" styleClass="dpad-combo"
                                  prefWidth="90" onAction="#onMappingChanged"/>
                    </HBox>
                </HBox>

                <!-- Down -->
                <HBox alignment="CENTER" prefHeight="60">
                    <ComboBox fx:id="downCombo" styleClass="dpad-combo"
                              prefWidth="90" onAction="#onMappingChanged"/>
                </HBox>

                <!-- Click -->
                <HBox alignment="CENTER" spacing="8" prefHeight="40">
                    <Label text="● CLICK" styleClass="dpad-label"
                           style="-fx-font-size: 10px;"/>
                    <ComboBox fx:id="clickCombo" styleClass="dpad-combo"
                              prefWidth="90" onAction="#onMappingChanged"/>
                </HBox>

            </VBox>

            <Separator/>

            <!-- Deadzone -->
            <VBox spacing="10">
                <Label text="DEADZONE" styleClass="card-title"/>
                <Label text="← Less sensitive    More sensitive →"
                       styleClass="stat-label"
                       style="-fx-font-size: 9px; -fx-text-fill: #646d7a;"/>

                <!-- Directional deadzone -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Directional" styleClass="stat-label"
                           style="-fx-min-width: 80px;"/>
                    <Slider fx:id="thresholdSlider" min="50" max="150"
                            value="30"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            showTickMarks="false" styleClass="sensitivity-slider"/>
                    <Label fx:id="thresholdLabel" text="120"
                           styleClass="value"
                           style="-fx-min-width: 32px; -fx-font-size: 11px;"/>
                </HBox>

                <!-- Diagonal deadzone -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Diagonal" styleClass="stat-label"
                           style="-fx-min-width: 80px;"/>
                    <Slider fx:id="diagonalSlider" min="30" max="100"
                            value="40"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            showTickMarks="false" styleClass="sensitivity-slider"/>
                    <Label fx:id="diagonalLabel" text="60"
                           styleClass="value"
                           style="-fx-min-width: 32px; -fx-font-size: 11px;"/>
                </HBox>
            </VBox>

            <!-- Actions -->
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="resetButton" text="Reset"
                        onAction="#onResetClicked" styleClass="btn-secondary"
                        style="-fx-padding: 5 12 5 12; -fx-font-size: 10px;"/>
                <Button fx:id="saveAsProfileButton" text="Save as Profile"
                        onAction="#onSaveAsProfileClicked" styleClass="btn-secondary"
                        style="-fx-padding: 5 12 5 12; -fx-font-size: 10px;"/>
                <Button fx:id="saveButton" text="Apply"
                        onAction="#onSaveClicked" styleClass="btn-primary"
                        style="-fx-padding: 5 12 5 12; -fx-font-size: 10px;"/>
            </HBox>

        </VBox>

        <!-- Right — Built-in Presets -->
        <VBox styleClass="card" spacing="12"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <Label text="BUILT-IN PRESETS" styleClass="card-title"/>
            <VBox fx:id="builtinProfilesList" spacing="8" VBox.vgrow="ALWAYS"/>
        </VBox>

    </HBox>

    <!-- Bottom row — Custom Profiles -->
    <VBox styleClass="card" spacing="12"
          VBox.vgrow="ALWAYS" maxHeight="Infinity">

        <HBox alignment="CENTER_LEFT">
            <Label text="CUSTOM PROFILES" styleClass="card-title" HBox.hgrow="ALWAYS"/>
            <Label fx:id="customCountLabel" text="0 / 10"
                   styleClass="text-secondary"
                   style="-fx-font-size: 10px;"/>
        </HBox>

        <Label fx:id="noCustomLabel" text="No custom profiles yet."
               styleClass="text-secondary"
               style="-fx-font-size: 11px;"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    styleClass="profile-scroll">
            <VBox fx:id="customProfilesList" spacing="8"/>
        </ScrollPane>

    </VBox>

</VBox>
