<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.juviscript.compassmeridian.controllers.SaveProfileModalController"
      styleClass="modal-root"
      spacing="0"
      prefWidth="380">

    <!-- Modal titlebar -->
    <HBox styleClass="modal-titlebar" alignment="CENTER_LEFT"
          onMousePressed="#onTitlebarPressed"
          onMouseDragged="#onTitlebarDragged">
        <Label text="SAVE AS PROFILE" styleClass="modal-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="btn-close" onAction="#onCancelClicked"/>
    </HBox>

    <!-- Content -->
    <VBox spacing="16" style="-fx-padding: 24;">

        <!-- Name input -->
        <VBox spacing="6">
            <Label text="PROFILE NAME" styleClass="card-title"/>
            <TextField fx:id="profileNameField"
                       styleClass="device-name-field"
                       promptText="Enter profile name..."
                       onKeyPressed="#onKeyPressed"/>
            <Label fx:id="nameError" text="" styleClass="text-secondary"
                   style="-fx-text-fill: #cc0000; -fx-font-size: 10px;"/>
        </VBox>

        <!-- Mapping preview -->
        <VBox spacing="8">
            <Label text="MAPPING PREVIEW" styleClass="card-title"/>
            <GridPane hgap="16" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="80"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="80"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="↑ UP" styleClass="dpad-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="previewUp" text="w" styleClass="preview-value"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="↓ DOWN" styleClass="dpad-label"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="previewDown" text="s" styleClass="preview-value"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="← LEFT" styleClass="dpad-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <Label fx:id="previewLeft" text="a" styleClass="preview-value"
                       GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="→ RIGHT" styleClass="dpad-label"
                       GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <Label fx:id="previewRight" text="d" styleClass="preview-value"
                       GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="● CLICK" styleClass="dpad-label"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="previewClick" text="SPACE" styleClass="preview-value"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Directional" styleClass="dpad-label"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="previewThreshold" text="120" styleClass="preview-value"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Diagonal" styleClass="dpad-label"
                       GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                <Label fx:id="previewDiagonal" text="60" styleClass="preview-value"
                       GridPane.rowIndex="3" GridPane.columnIndex="3"/>

            </GridPane>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button text="Cancel" styleClass="btn-secondary"
                    onAction="#onCancelClicked"/>
            <Button fx:id="saveButton" text="Save Profile"
                    styleClass="btn-primary"
                    onAction="#onSaveClicked"/>
        </HBox>

    </VBox>

</VBox>
